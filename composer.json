	"autoload" : {
		"psr-4" : {
			"n2n\\util\\attr\\" : "src/app/n2n/util/attr"
		}
	},
	"autoload-dev" : {
		"psr-4" : {
			"n2n\\util\\attr\\" : "src/test/n2n/util/attr"
		}
	}
}
